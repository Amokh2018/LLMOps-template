# Development Environment Configuration

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Vertex AI Configuration
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# Vector Store Configuration
VECTOR_STORE_INDEX_ID=your-vector-index-id
VECTOR_STORE_ENDPOINT=your-vector-index-endpoint

# Cloud Storage
GCS_BUCKET=your-documents-bucket
GCS_INGESTION_PREFIX=documents/

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (if using Cloud Firestore or similar)
DB_TYPE=firestore

# Retrieval Configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_DISTANCE_THRESHOLD=0.7

# Auth (if needed)
API_KEY_HEADER=X-API-Key
