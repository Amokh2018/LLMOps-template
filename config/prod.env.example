# Production Environment Configuration

# GCP Configuration
GCP_PROJECT_ID=your-prod-gcp-project-id
GCP_REGION=us-central1

# Vertex AI Configuration
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# Vector Store Configuration
VECTOR_STORE_INDEX_ID=your-prod-vector-index-id
VECTOR_STORE_ENDPOINT=your-prod-vector-index-endpoint

# Cloud Storage
GCS_BUCKET=your-prod-documents-bucket
GCS_INGESTION_PREFIX=documents/

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
CORS_ORIGINS=https://your-domain.com

# Database
DB_TYPE=firestore

# Retrieval Configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_DISTANCE_THRESHOLD=0.7

# Auth
API_KEY_HEADER=X-API-Key

# Monitoring
ENABLE_CLOUD_LOGGING=true
ENABLE_CLOUD_TRACE=true
ENABLE_CLOUD_PROFILER=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
